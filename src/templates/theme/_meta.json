{
  "id": "theme",
  "label": "Magento: Create Theme",
  "command": "magento.createTheme",
  "contextMenu": {
    "when": "explorerResourceIsFolder && resourcePath =~ /.*[/\\\\]app[/\\\\]design[/\\\\]frontend$/",
    "group": "magento@1"
  },
  "steps": [
    {
      "id": "packageName",
      "type": "input",
      "label": "Vendor / Package Name",
      "placeholder": "e.g. MyCompany",
      "validate": "pascal-case"
    },
    {
      "id": "themeName",
      "type": "input",
      "label": "Theme Name",
      "placeholder": "e.g. Default",
      "validate": "pascal-case"
    },
    {
      "id": "parentTheme",
      "type": "select",
      "label": "Parent Theme",
      "source": "installedThemes"
    },
    {
      "id": "version",
      "type": "input",
      "label": "Version",
      "placeholder": "e.g. 1.0.0",
      "default": "1.0.0",
      "validate": "semver"
    },
    {
      "id": "license",
      "type": "multi-select",
      "label": "License(s)",
      "source": "licenses"
    }
  ],
  "outputPath": "{{packageName}}/{{themeName}}"
}
